<DownloaderLayout>:
    orientation: "vertical"
    padding: 10
    spacing: 10

    canvas.before:
        Color:
            rgba: 0.02, 0.06, 0.1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: "Reyette Downloader"
        font_size: 34
        bold: True
        color: 0.4, 0.7, 1, 1
        halign: "center"

    TextInput:
        id: url
        hint_text: "Masukkan URL (YouTube, TikTok, Facebook, Instagram, Twitter/X)"
        size_hint_y: None
        height: 40
        background_color: 0.1, 0.15, 0.2, 1   # biru gelap
        foreground_color: 1, 1, 1, 1
        padding: [12, 12]
        font_size: 15

    BoxLayout:
        size_hint_y: None
        height: 50
        spacing: 12

        Spinner:
            id: mode
            text: "MP4"
            values: ["MP4", "MP3"]
            background_color: 0.15, 0.2, 0.25, 1
            color: 0.8, 0.9, 1, 1
            font_size: 15

        Spinner:
            id: quality
            text: "max"
            values: ["360p", "480p", "720p", "1080p", "max"]
            background_color: 0.15, 0.2, 0.25, 1
            color: 0.8, 0.9, 1, 1
            font_size: 15

    Button:
        text: "Download"
        size_hint_y: None
        height: 50
        background_color: 0.0, 0.5, 0.7, 1   # biru laut terang
        color: 1, 1, 1, 1
        bold: True
        font_size: 16
        on_press: root.start_download()

    TextInput:
        id: log
        readonly: True
        size_hint_y: 4
        background_color: 0.05, 0.07, 0.1, 1
        foreground_color: 0.3, 0.9, 1, 1
        font_size: 10
        padding: [10, 10]
        multiline: True
    
    Label:
        text: "Copyright © 2026 Reyette Downloader. All rights reserved."
        font_size: 8
        bold: False
        color: 0.4, 0.7, 1, 1
        halign: "center"
